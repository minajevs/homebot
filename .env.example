# Created by @BotFather. Treat this like a password; never commit it.
TELEGRAM_BOT_TOKEN=123456789:replace-me

# Comma-separated numeric Telegram user IDs. Leave empty only temporarily to use /whoami.
# Example: ALLOWED_USER_IDS=123456789,987654321
ALLOWED_USER_IDS=

# Comma-separated chat IDs the bot listens in (group IDs are negative).
# Leave empty to allow private chats only. Get the ID with /chatid in the group.
# Example: ALLOWED_CHAT_IDS=-1001234567890
ALLOWED_CHAT_IDS=

# Where rain readings are stored. Keep this outside the app directory in production.
RAIN_DATA_FILE=data/rain.json

# Weekly rain summary posted to the first allowed chat: "<day> <HH:MM>" local time, or "off".
RAIN_REMINDER=saturday 09:00

# Local timezone, so the Monday week reset and the reminder match your clock.
TZ=Europe/Riga

# Human-readable label used in replies and logs.
BOT_NAME=HomeBot
